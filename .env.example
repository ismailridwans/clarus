# Copy this file to .env and fill in your values.
# .env is gitignored — it will never be committed.
#
# Usage:
#   cp .env.example .env
#   # edit .env with your token
#   python inference.py

# Required: your HuggingFace API token
# Get one at: https://huggingface.co/settings/tokens  (Role: Read is enough)
HF_TOKEN=hf_...

# Optional: override the LLM endpoint (default is HuggingFace router)
API_BASE_URL=https://router.huggingface.co/v1

# Optional: override the model (default is Qwen 72B)
MODEL_NAME=Qwen/Qwen2.5-72B-Instruct
